# ════════════════════════════════════════════════════════════════
#  Ladybug — RunPod GPU Worker Environment
#  Used by: docker/runpod/Dockerfile + start.sh
#  Copy this to your RunPod pod as /app/.env
#  OR paste each variable into RunPod dashboard → Environment Variables
# ════════════════════════════════════════════════════════════════


# ── Database ─────────────────────────────────────────────────────
# RunPod needs DB access for ModelRepository.create_model_run()
DB_TYPE=postgresql
DB_SYNC_DRIVER=psycopg2
DB_HOST=your-postgres-host.com
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name


# ── LLM Configuration ────────────────────────────────────────────
# Only needed if RunPod task ever calls GPT (labeling runs on CPU worker)
# Safe to include anyway
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...your-key...
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_MAX_INPUT_CHARS=4000
OPENAI_MAX_OUTPUT_TOKENS=256
OPENAI_TEMPERATURE=0.0
OPENAI_INPUT_PRICING=0.00015
OPENAI_OUTPUT_PRICING=0.0006


# ── Cloud Storage (AWS S3) ────────────────────────────────────────
# RunPod downloads training data FROM S3 and uploads model TO S3
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name


# ── Training Backend ─────────────────────────────────────────────
TRAINING_BACKEND=runpod


# ── Celery — CloudAMQP (cloud RabbitMQ) ──────────────────────────
# Get this URL from: https://cloudamqp.com → your instance → AMQP URL
# Format: amqps://user:password@host/vhost
CELERY_BROKER_URL=amqps://your_user:your_password@your_host.cloudamqp.com/your_vhost


# ── Celery — Upstash Redis ────────────────────────────────────────
# Get this URL from: https://console.upstash.com → your db → Connect → redis-py
# Format: rediss://:password@host:port
CELERY_RESULT_BACKEND=rediss://:your_upstash_password@your_host.upstash.io:6379


# ── Celery Worker Settings ────────────────────────────────────────
CELERY_TASK_SERIALIZER=json
CELERY_TASK_TIME_LIMIT=86400
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_CONCURRENCY_CPU=4
CELERY_WORKER_CONCURRENCY_GPU=1
# GPU concurrency must always be 1 — one GPU task at a time
