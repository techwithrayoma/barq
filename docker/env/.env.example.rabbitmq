# RabbitMQ Configuration Example
RABBITMQ_DEFAULT_USER=ladybug_user
RABBITMQ_DEFAULT_PASS=ladybug_rabbitmq_2222
RABBITMQ_DEFAULT_VHOST=ladybug_vhost

# Management Plugin
RABBITMQ_MANAGEMENT_ENABLED=true

# Security
RABBITMQ_AUTH_BACKENDS=rabbit_auth_backend_internal

# Performance
RABBITMQ_DISK_FREE_LIMIT=2000000000